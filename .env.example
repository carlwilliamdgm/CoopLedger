# Configuration des clés Stellar pour CoopLedger
# Copiez ce fichier en .env et remplacez les valeurs par vos vraies clés

# Clé publique du compte Stellar (commence par G)
PUBLIC_KEY=GA...

# Clé secrète du compte Stellar (commence par S)
SECRET_KEY=SA...

# Port du serveur (optionnel, défaut 3000)
PORT=3000

# URL de connexion PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/coopledger

# Secret utilise pour signer les JWT
JWT_SECRET=change-me

# Stellar (optionnel : STELLAR_PUBLIC_KEY / STELLAR_SECRET_KEY sinon PUBLIC_KEY / SECRET_KEY)
# STELLAR_NETWORK=testnet
# STELLAR_HORIZON_URL=
# STELLAR_EXPERT_TX_BASE=

# URL publique de l app (webhook FedaPay : /api/cotisations/webhook)
# APP_URL=https://votre-domaine.example

# FedaPay — base API sans slash final (sandbox par defaut ; production : https://api.fedapay.com)
# FEDAPAY_API_BASE_URL=https://sandbox-api.fedapay.com
# FEDAPAY_SERVER_KEY=
# FEDAPAY_PUBLIC_KEY=
# FEDAPAY_WEBHOOK_SECRET=

# Connexion admin (tableau de bord)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# Web Push (optionnel)
# VAPID_SUBJECT=mailto:contact@example.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
